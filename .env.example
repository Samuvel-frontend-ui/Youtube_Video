# .env.example
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Backend API (backend/src/server.ts). Default 3001.
PORT=3001

# Optional: full origin when the UI is not served from the same host as the API
# (leave unset in dev — Vite proxies /api to the backend)
# VITE_API_URL=http://localhost:3001

# Optional: where Vite should proxy /api (default http://localhost:3001)
# VITE_BACKEND_URL=http://localhost:3001

# Vite dev server port (default 3000 so http://localhost:3000 matches the app + /api proxy)
# VITE_DEV_PORT=3000

# Backend: do not set YOUTUBE_DL_SKIP_DOWNLOAD — youtube-dl-exec needs its postinstall
# to download yt-dlp into backend/node_modules/youtube-dl-exec/bin/

# --- Vercel (production UI + serverless API) ---
# Leave VITE_API_URL unset so the browser calls same-origin /api (rewritten to api/index.ts).
# Large downloads need ffmpeg; Vercel serverless has time/size limits — for heavy use, host the
# Express app (backend/) on a VPS/Railway/Render and set VITE_API_URL to that origin at build time.
