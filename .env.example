# .env.example

# Production / preview (Vercel): set to your Render (or other) API origin — no trailing slash.
# VITE_API_URL=https://your-api.onrender.com

# Local dev: `npm run dev` runs Vite + uvicorn (backend-python). Vite proxies /api → http://127.0.0.1:8000
# pip install -r backend-python/requirements.txt
# VITE_BACKEND_URL=http://127.0.0.1:8000

# VITE_DEV_PORT=3000

# Python API (Render / local): optional Cookie header for bot-gated videos (private use only)
# YOUTUBE_COOKIE=

# Python API: CORS — your Vercel app URL(s), comma-separated, or * for testing
# FRONTEND_ORIGIN=https://your-app.vercel.app
