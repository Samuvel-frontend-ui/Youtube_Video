# Copy to .env — Vite reads from frontend/

# Production: Vite loads .env.production on `vite build`. Vercel can also set VITE_API_URL.
# If unset/empty, `src/services/api.ts` still falls back to the same Render URL (avoids POST→static 405).
# VITE_API_URL=https://yt-backend-ys8d.onrender.com

# Local: proxy /api → this host (default http://127.0.0.1:8000)
# VITE_BACKEND_URL=http://127.0.0.1:8000

# VITE_DEV_PORT=3000
