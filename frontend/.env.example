# Copy to .env — Vite reads from frontend/

# Production: Vite loads .env.production on `vite build` (committed in this repo for Render API).
# Or set VITE_API_URL in Vercel → Environment Variables (overrides .env.production).
# VITE_API_URL=https://yt-backend-ys8d.onrender.com

# Local: proxy /api → this host (default http://127.0.0.1:8000)
# VITE_BACKEND_URL=http://127.0.0.1:8000

# VITE_DEV_PORT=3000
